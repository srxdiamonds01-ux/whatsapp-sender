# Copy this file to ".env" and fill in your values.

# ===== App config =====
SESSION_SECRET=change-this-to-any-random-string

# ===== Google Login + Google Contacts (OAuth) =====
# Create these at https://console.cloud.google.com  (APIs & Services > Credentials > OAuth client ID > Web app)
# ALSO enable "People API" in the same project (needed to save numbers to Google Contacts).
# Leave blank to disable Google login (Email/Password still works).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Add this exact URL under "Authorized redirect URIs" in the Google Console:
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ===== Gemini AI (optional: smart auto-reply + template generator) =====
# Free API key: https://aistudio.google.com/apikey
# Leave blank to disable AI features (fixed-template auto-reply still works).
GEMINI_API_KEY=
# Comma-separated list: if the first model is quota-exhausted (429) the server auto-switches to the next.
# Leave blank to use the built-in fallback list.
GEMINI_MODEL=gemini-2.5-flash,gemini-2.0-flash,gemini-2.5-flash-lite,gemini-flash-latest
